# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Inhalts-Quellen (MD-Drafts), aus denen App-Module kompiliert wurden.
# Werden NICHT deployt, dienen nur als Archiv und für künftige Updates.
content-sources/

# Persönliche Notizen, Social-Media-Drafts, Projektbeschreibungen.
# Nicht Teil des Repos.
dev-notes/

# Node (falls npm-Skripte genutzt werden)
node_modules/
package-lock.json

# Logs / temp
*.log
.tmp/
.cache/
build/

# Lighthouse reports (lokale Audits, nicht im Repo)
lighthouse-*.json

# Pre-Compression-Output: wird von scripts/compress.js erzeugt und
# beim Deploy nach public/ rsync'd. Nicht im Repo halten — die Brotli-
# Outputs ändern sich bei jedem index.html-Edit (großer Diff-Lärm).
public/*.gz
public/*.br
public/icons/*.gz
public/icons/*.br
